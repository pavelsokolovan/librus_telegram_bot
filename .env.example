# Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Account 1 — first child
# Accounts are auto-discovered: just set LIBRUS_USERNAME{id} + LIBRUS_PASSWORD{id} + TELEGRAM_CHAT_IDS{id}
# No changes to config.json needed when adding accounts.
ACCOUNT_NAME1=YourChildName
LIBRUS_USERNAME1=your_librus_username
LIBRUS_PASSWORD1=your_librus_password
TELEGRAM_CHAT_IDS1=123456789

# Account 2 — second child (add this block to enable a second account; delete if not needed)
# ACCOUNT_NAME2=YourSecondChildName
# LIBRUS_USERNAME2=your_librus_username
# LIBRUS_PASSWORD2=your_librus_password
# TELEGRAM_CHAT_IDS2=123456789
